{
  "name": "quantan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "validate:data": "node scripts/validate-data-samples.mjs",
    "check:smoke": "node scripts/smoke-production.mjs",
    "check:smoke:extended": "node scripts/run-smoke-extended.mjs",
    "check:smoke:local": "node scripts/run-smoke-local.mjs",
    "check:smoke:local:extended": "node scripts/run-smoke-local-extended.mjs",
    "check:smoke:local:nosearch": "node scripts/run-smoke-local-nosearch.mjs",
    "check:smoke:local:extended:nosearch": "node scripts/run-smoke-local-extended-nosearch.mjs",
    "verify:logic": "node scripts/verify-core-logic.mjs",
    "verify:indicators": "node scripts/verify-indicator-math.mjs",
    "verify:btc": "node scripts/verify-btc-ohlc-sample.mjs",
    "verify:integrity": "node scripts/verify-data-integrity.mjs",
    "diagnose:crypto": "node scripts/diagnose-crypto.mjs",
    "verify:data": "npm run verify:logic && npm run verify:indicators && npm run verify:btc && npm run verify:integrity",
    "check:all": "npm run verify:data && npm run validate:data && npm run check:smoke",
    "check:ci": "npm run verify:data && npm run check:smoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "npx tsx --tsconfig tsconfig.json scripts/benchmark-signals.ts",
    "benchmark:oos": "npx tsx --tsconfig tsconfig.json scripts/oos-validation.ts",
    "benchmark:oos:wf": "npx tsx --tsconfig tsconfig.json scripts/oos-walkforward.ts",
    "experiment:rotation": "npx tsx --tsconfig tsconfig.json scripts/experiments/rotation-walkforward.ts",
    "benchmark:enhanced": "npx tsx --tsconfig tsconfig.json scripts/benchmark-enhanced.ts",
    "optimize:grid": "npx tsx --tsconfig tsconfig.json scripts/optimize-grid.ts",
    "portfolio:backtest": "npx tsx --tsconfig tsconfig.json scripts/portfolio-backtest.ts",
    "stryker": "stryker run"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "lightweight-charts": "^4.1.3",
    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "next-auth": "^4.24.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swr": "^2.2.5",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.0.1",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "pathe": "^2.0.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vercel": "^50.35.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
