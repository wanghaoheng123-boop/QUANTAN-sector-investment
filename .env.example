# QUANTAN Environment Variables
# Copy this file to .env.local and fill in values. DO NOT commit .env.local.

# ─── AI / LLM ───────────────────────────────────────────────────
# DeepSeek V4 Pro (Anthropic-compatible endpoint)
ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
ANTHROPIC_AUTH_TOKEN="sk-YOUR_DEEPSEEK_API_KEY_HERE"
ANTHROPIC_MODEL="deepseek-v4-pro"
ANTHROPIC_THINKING_TYPE="enabled"
ANTHROPIC_THINKING_BUDGET_TOKENS="128000"

# OpenAI (for TradingAgents)
#OPENAI_API_KEY=sk-...

# Anthropic (for TradingAgents)
#ANTHROPIC_API_KEY=sk-ant-...

# ─── Next.js / NextAuth ─────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Optional: OAuth providers
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# ─── TradingAgents Python Backend ───────────────────────────────
#TRADING_AGENTS_BASE=https://your-app.up.railway.app
#TRADING_AGENTS_FALLBACK_BASE=https://shared-tradingagents.your-domain.com
# Server-to-server auth for POST /api/trading-agents/[ticker] (D4-1).
# Callers send this exact value in the `X-API-Key` header to bypass the
# browser CSRF guard. Fail-closed: while this is UNSET, the X-API-Key path
# rejects ALL requests (only an authenticated session can POST). Set a long
# random secret (e.g. `openssl rand -hex 32`) in Vercel env — never commit a value.
#QUANTAN_API_KEY=

# ─── External Data APIs ─────────────────────────────────────────
#POLYGON_API_KEY=
#ALPHA_VANTAGE_API_KEY=
#FRED_API_KEY=

# ─── Vercel KV rate limiting (Q-005) ────────────────────────────
# Distributed 429 enforcement (lib/api/rateLimit.ts). Falls back to per-process Map when unset.
# Vercel: Storage → KV → link project → redeploy (auto-injects KV_REST_*).
#KV_REST_API_URL=https://YOUR-DB.upstash.io
#KV_REST_API_TOKEN=YOUR_UPSTASH_REST_TOKEN

# ─── Feature flags (Q-009) ──────────────────────────────────────
# Q-067 shadow signal log (2026-07-16): records what /api/backtest/live served.
# Sinks: Redis via the SAME KV_REST_* pair above (provisioning marketplace
# Redis activates rate limiting AND the shadow log); local dev falls back to
# workspace/shadow/*.jsonl; no sink = no-op. Set 0 to disable entirely.
#QUANTAN_SHADOW_LOG=1
# Override the local shadow-log directory (tests/dev only).
#QUANTAN_SHADOW_DIR=

#QUANTAN_USE_ENHANCED_SIGNAL=0
#QUANTAN_CSP_ENFORCE=0
#QUANTAN_FRED_PREWARM=1
#QUANT_FRAMEWORK_URL=

# ─── App URL (server-side fetches, briefs) ───────────────────────
#NEXT_PUBLIC_APP_URL=https://quantan.vercel.app

# ─── Bloomberg Bridge (optional) ────────────────────────────────
#BLOOMBERG_BRIDGE_URL=http://localhost:8080
